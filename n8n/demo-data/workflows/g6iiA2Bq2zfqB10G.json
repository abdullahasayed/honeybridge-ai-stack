      ],
      "id": "62d1357c-1c02-4f41-923c-002f4640231c",
      "name": "Execute Command"
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and extract image filenames from document.md_content\nfor (const item of $input.all()) {\n  // The markdown lives at item.json.document.md_content\n  const content = item.json.document?.md_content || '';\n\n  // Regex matches: ![Image](image_NNNNNN_<hash>.png)\n  const regex = /!\\[Image\\]\\((image_\\d+_[a-f0-9]+\\.(?:png|jpg|jpeg|gif|webp))\\)/gi;\n\n  const imageNames = [];\n  let match;\n  while ((match = regex.exec(content)) !== null) {\n    imageNames.push(match[1]);\n  }\n\n  item.json.imageNames = imageNames;\n  item.json.imageCount = imageNames.length;\n}\n\nreturn $input.all();"
      },
