    {
      "parameters": {
        "jsCode": "// Base URL where images are hosted\nconst BASE_URL = 'http://localhost:8080/';\n\n// Loop over input items and inject full image URLs into md_content\nfor (const item of $input.all()) {\n  // The document object may be nested directly or under .document\n  const doc = item.json.document || item.json;\n\n  if (doc && typeof doc.md_content === 'string') {\n    // Replace markdown image refs ![alt](image_xxx.png) with full URL\n    // Only rewrites paths that are NOT already absolute (no http/https///)\n    doc.md_content = doc.md_content.replace(\n      /!\\[([^\\]]*)\\]\\((?!https?:\\/\\/|\\/\\/)([^)\\s]+)\\)/g,\n      (match, altText, imgPath) => {\n        // Strip any leading ./ or / so we don't double up slashes\n        const cleanPath = imgPath.replace(/^\\.?\\//, '');\n        return `![${altText}](${BASE_URL}${cleanPath})`;\n      }\n    );\n\n    // Optional: keep the original behaviour of adding a marker field\n    doc.myNewField = 1;\n  }\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
